*{
	margin: 0;
	padding:0;
	background-color: #041C32;
}
.container{
	height: 100vh;
	width: 100%;
	display: flex;
	justify-content: center;
	align-items: center;

}
.card{
	width: 47vh;
	border: 1px solid transparent;
	box-shadow: 0 8px 16px -0.8PX BLACK; 
	height: 570px;
	border-radius: 10PX;
    background: #16213E;
}